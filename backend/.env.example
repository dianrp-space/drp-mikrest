# drp-mikrest backend environment
# Salin file ini ke .env lalu sesuaikan nilai.

# Server
APP_ENV=development
APP_PORT=8080
APP_SECRET=change-me-to-a-long-random-string-min-32-chars
ENCRYPTION_KEY=another-long-random-string-min-32-chars-here
DISABLE_REGISTRATION=true

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=db_password
DB_NAME=drp_mikrest
DB_SSLMODE=disable
DB_MAX_CONNS=10

# JWT
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# CORS frontend origin (Domain yang diizinkan untuk mengakses API)
CORS_ORIGIN=http://localhost:5173
